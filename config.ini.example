[server]
port=8080
resource_dir=./fronted

[performance]
io_pool_size=0
thread_pool_size=4
timeout=30

[database]
db_host=localhost
db_port=5432
db_name="your_database"
db_user="your_username"
db_password= "your_password"; please chmod 600 this file
db_pool_size=8

[security]
enable_ssl=false

[advanced]
max_body_size=1048576
keep_alive=true
log_level=info